# Configuración de la aplicación
# Copiar a .env y completar con valores reales — NUNCA commitear .env con secretos

# Base de datos (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/activia_trace

# Base de datos para tests (efímera, separada de la de desarrollo)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/activia_trace_test

# Seguridad JWT — generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_en_produccion_genera_con_secrets_token_hex_32

# Clave de cifrado AES-256 para PII (CBU, DNI, email cifrado) — 32 bytes en hex
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=cambia_esto_en_produccion_genera_con_secrets_token_hex_32

# Duración del access token en minutos (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración del refresh token en días (default: 30)
REFRESH_TOKEN_EXPIRE_DAYS=30

# Entorno: development | production | test
ENVIRONMENT=development

# OpenTelemetry — dejar vacío para deshabilitar exportación (app arranca igual)
OTLP_ENDPOINT=
